    private void workdayButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_connectionButtonActionPerformed

		//workdayButton.setEnabled(false);
   // 1. Ottieni i dati selezionati

		LogMessageTableModel table = (LogMessageTableModel) logTable.getModel();

        int[] selectedRows = logTable.getSelectedRows();
        int[] selectedCols = logTable.getSelectedColumns();

        TableModel model = table;
        
        if (selectedRows.length == 0 || selectedCols.length == 0) 
		{
		
			return;
		}
		
        StringBuilder buffer = new StringBuilder();

        // 2. Costruisci la stringa (Tab separata)
        for (int i = 0; i < selectedRows.length; i++) 
		{
            for (int j = 0; j < selectedCols.length; j++) 
			{
                Object value = model.getValueAt(selectedRows[i], selectedCols[j]);

				buffer.append(value == null ? "" : value.toString());

                if (j < selectedCols.length - 1) 
					buffer.append("\t");
            }

			if (i < selectedRows.length - 1) 
				buffer.append("\n");
        }

        // 3. Copia negli appunti
        StringSelection stringSelection = new StringSelection(buffer.toString());
        Clipboard clipboard = Toolkit.getDefaultToolkit().getSystemClipboard();
        clipboard.setContents(stringSelection, null);
        
        System.out.println("Dati copiati negli appunti.");
    	
	
    }//GEN-LAST:event_connectionLabelActionPerformed



