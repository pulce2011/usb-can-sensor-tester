	protected void CAN_PostUpgradeMsg(CANMessage __new_msg) {
			rxCanUpgradeQueueLock.lock();
			
			rxCanUpgradeQueue.add(__new_msg);

			rxCanUpgradeQueueLock.unlock();
		};
	

