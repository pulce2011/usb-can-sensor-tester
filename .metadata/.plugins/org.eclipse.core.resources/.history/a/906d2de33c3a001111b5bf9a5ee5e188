	class UpgradeTask extends TimerTask 
	{
        int statoUpgrade = 0;
        int cntDataPack = 0;
        int cntAddrPack = 0;
		int delayPollStatus = 0;
		CANMessage txMsgStatus 		= new CANMessage("t601840005F0000000000");
		CANMessage txMsgAddress;
		CANMessage txMsgEnProg 		= new CANMessage("t601820005F021A2A3A4A");
		CANMessage txMsgDisProg 	= new CANMessage("t601820005F025A6A7A8A");
		CANMessage txMsgErase 		= new CANMessage("t601820005F031E2E3E4E");
		CANMessage txMsgDoCrcCalc 	= new CANMessage("t601820005F0611111111");
		CANMessage txMsgRdCrcProg 	= new CANMessage("t601840005F0700000000");
		CANMessage txMsgRdCrcCalc 	= new CANMessage("t601840005F0800000000");
		CANMessage txMsgJmpToBoot	= new CANMessage("t601820005F0111223344");
		CANMessage txMsgData;
		CANMessage rxMsg; 

		int sdo_client_id = 0x601;
		int sdo_server_id = 0x581;
		int sdo_fn_write = 0x20;
		int sdo_fn_read = 0x40;
		int sdo_upg_index = 0x5F00;
		int sdo_sub_status = 0;
		int sdo_sub_jump = 1;
		int sdo_sub_enprog = 2;
		int sdo_sub_erase = 3;
		int sdo_sub_wraddr = 4;

		byte[] can_data; 
	    String s;
		String strTxMsg;
		int appStat;
		int eraseStat;
		int crcStat;
		int writeStat;
		SREC upgradeRec;
		int cntSentStatus;

				// sub 2 = attiva prog.
				// sub 3 = flash erase.
				// sub 4 = flash address
				// sub 0x80-0xFF = flash indexed data
				
		public void run() 
		{

			rxCanUpgradeQueueLock.lock();

			rxMsg = rxCanUpgradeQueue.poll();

			rxCanUpgradeQueueLock.unlock();

			if( rxMsg != null )
			{

				can_data = rxMsg.getData();

                s = "";

                for (int i = 0; i < can_data.length; i++) 
				{
                    s = s.concat(String.format(" %02x", can_data[i]));
                }

//				System.out.println("can SDO:"+ String.format("0x%03x", rxMsg.getId()) + s + rxMsg.getData().length);

//				System.out.println("can Rx:"+ String.format("0x%03x", rxMsg.getId()) + s);

			}

			switch( statoUpgrade )
			{
				case	0:
                	//System.out.println("upgrade started!");


					String strName = upgradeFileName.getText();
					
					if( strName.charAt(1) == '1' )
					{
						sdo_client_id = 0x601;
						sdo_server_id = 0x581;
					}

					if( strName.charAt(1) == '2' )
					{
						sdo_client_id = 0x602;
						sdo_server_id = 0x582;
					}

					if( strName.charAt(1) == '3' )
					{
						sdo_client_id = 0x603;
						sdo_server_id = 0x583;
					}

					if( strName.charAt(1) == '4' )
					{
						sdo_client_id = 0x604;
						sdo_server_id = 0x584;
					}

					if( strName.charAt(1) == 'A' )      // primo micro M185
					{
						sdo_client_id = 0x60A;
						sdo_server_id = 0x58A;
					}
					if( strName.charAt(1) == 'B' )
					{
						sdo_client_id = 0x60B;
						sdo_server_id = 0x58B;
					}


					if( strName.charAt(1) == 'C' )
					{
						sdo_client_id = 0x60C;
						sdo_server_id = 0x58C;
					}

					if( strName.charAt(1) == 'D' )
					{
						sdo_client_id = 0x60D;
						sdo_server_id = 0x58D;
					}

					if( strName.charAt(1) == 'E' )      // primo micro M185
					{
						sdo_client_id = 0x60E;
						sdo_server_id = 0x58E;
					}
					if( strName.charAt(1) == 'F' )
					{
						sdo_client_id = 0x60F;
						sdo_server_id = 0x58F;
					}

					
					log(String.format("upgrade started! sever Id is: %02X ",  sdo_server_id), LogMessage.MessageType.INFO);

					txMsgStatus.setId(sdo_client_id);
					txMsgEnProg.setId(sdo_client_id);
					txMsgDisProg.setId(sdo_client_id);
					txMsgErase.setId(sdo_client_id);

					txMsgDoCrcCalc.setId(sdo_client_id);
					txMsgRdCrcProg.setId(sdo_client_id);
					txMsgRdCrcCalc.setId(sdo_client_id);
					txMsgJmpToBoot.setId(sdo_client_id);					

        			cntDataPack = 0;
        			cntAddrPack = 0;
					statoUpgrade++;
					break;

				case	1:
                	//System.out.println("check for boot ..");

					log("check for boot ..", LogMessage.MessageType.INFO);
					send(txMsgStatus);
					delayPollStatus = 0;

					statoUpgrade++;
					break;

				case	2:

					if( rxMsg != null )
					{

						if( rxMsg.getId() == sdo_server_id )		// se siamo in boot ... procede
						{
							appStat = can_data[4] & 0xFF;
							
							if( appStat == 0x12 )
							{
	                			//System.out.println("enable prog ... ");
								log("enable prog ... ", LogMessage.MessageType.INFO);

								send(txMsgEnProg);

								statoUpgrade++;
							}
							else
							{
								if( appStat == 0x92 )		// boot ma programmazione attiva ?
								{
		                			//System.out.println("disable prog ... ");
									log("disable prog ... ", LogMessage.MessageType.INFO);

									send(txMsgDisProg);

									statoUpgrade = 201;
								}
								else
								{
									if( appStat == 0x21 )		// boot ma programmazione attiva ?
									{
										log("app running ... request jump", LogMessage.MessageType.INFO);

										send(txMsgJmpToBoot);									

										statoUpgrade = 205;		// aspetta la risposta e poi riconnette
									}
									else
									{
		                				System.out.println("prog boh ?");
										statoUpgrade = 202;
										// send(txMsgStatus);
									}
								}

							}
						}
	
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgStatus);
						}
					}			
					break;

				case	201:
					if( rxMsg != null )
					{
						appStat = can_data[4] & 0xFF;

						if( rxMsg.getId() == sdo_server_id && appStat == 0x12 )		// prog. disattivata ? ... procede
						{
					
	                		//System.out.println("disable ok... ");

							log("disable ok... ", LogMessage.MessageType.INFO);
							statoUpgrade = 1;
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgStatus);
						}
					}					
					break;

				case	202:
					send(txMsgStatus);

					statoUpgrade = 1;					
					break;

				case	205:		// attesa risposta per richiesta salto al boot
					if( rxMsg != null )
					{
						int msgSub = can_data[3] & 0xFF;

						if( rxMsg.getId() == sdo_server_id && msgSub == 1 )		// prog. disattivata ? ... procede
						{
							log("jmp request ok ... ", LogMessage.MessageType.INFO);
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 100 )		// ogni secondo prova a rimettere in modalita' config
						{
							delayPollStatus = 0;

							try {
								// rimette in modalita'config il CAN per poter impostare il setup al Loader
								if( usbtin.closeCANChannel() )		// mettiamo in modalita' config 
								{
									statoUpgrade = 206;
								}
							}
							catch (USBtinException e) 
							{
				                log(e.getMessage(), LogMessage.MessageType.ERROR);
				            }						
						}
					}
					break;

			case	206:		// rilegge la versione fw del proto sul loader e 
			
					try {
	    				/** USBtin firmware version */
	    				String firmwareVersion = usbtin.getFirmwareVersion();

						if( firmwareVersion == null )		// se non risponde ... forse non ci sta
						{
							log("Timeout! USBtin doesn't answer. Right boot?", LogMessage.MessageType.INFO);    			/** USBtin hardware version */
							statoUpgrade = 205;
						}
						else
						{

							try {
				    			String hardwareVersion = usbtin.getHardwareVersion();
				    			String serialNumber = usbtin.getSerialNumber();

								String strConnMsg = "Connected to USBtin (FW" + firmwareVersion + "/HW" + hardwareVersion + ", SN: " + serialNumber+ ")";
								log(strConnMsg, LogMessage.MessageType.INFO);

				                System.out.println(strConnMsg);

								usbtin.setCANBaudrate(Integer.parseInt((String) bitRate.getSelectedItem()));
			                	usbtin.openCANChannel((USBtin.OpenMode) openmodeComboBox.getSelectedItem());
							}
							catch (USBtinException e) 
							{
				                log(e.getMessage(), LogMessage.MessageType.ERROR);
				            }						
							
			                if (absTimestamp == 0) 
							{
			                    relTimestamp = absTimestamp = System.currentTimeMillis();
			                }

							statoUpgrade = 1;
						}
					}
					catch (USBtinException e) 
					{
		                log(e.getMessage(), LogMessage.MessageType.ERROR);
		            }											
					break;


				case	3:

					if( rxMsg != null )
					{
						appStat = can_data[4] & 0xFF;

						if( rxMsg.getId() == sdo_server_id && appStat == 0x92 )		// prog. attivata ? ... procede
						{					
		                	//System.out.println("erase start ... ");
							log("erase start ... ", LogMessage.MessageType.INFO);
							send(txMsgErase);

							cntSentStatus = 0;	
							delayPollStatus = 0;
							statoUpgrade++;
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgStatus);
						}
					}					

					break;

				case	4:

					if( rxMsg != null )
					{
						eraseStat = can_data[5] & 0xFF;

						if( rxMsg.getId() == sdo_server_id && eraseStat == 0x01 )		// erase terminato ? ... procede
						{
					
	                		//System.out.println("erase end... ");
							log("erase end... ", LogMessage.MessageType.INFO);
	
							upgradeRec = null;
							statoUpgrade++;
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;
							String strStatusNum = String.format("status request...  %d", cntSentStatus);

							if( cntSentStatus == 0 )
								log(strStatusNum, LogMessage.MessageType.INFO);
							else
								logUpdateLastMessage(strStatusNum, LogMessage.MessageType.INFO);

							cntSentStatus++;

							send(txMsgStatus);
						}
					}
					break;

				case	5:		// attiva programmazione: invia il primo indirizzo di flash da scrivere
                	//System.out.println("write start ... ");

					cntAddrPack = 0;

					log(String.format("valid srec tot: %d ",  alSREC.size()), LogMessage.MessageType.INFO);

 					if( alSREC.size() > 0 )
					{

						upgradeRec = alSREC.get(cntAddrPack);

						if( upgradeRec == null )
						{
							log("null start ... ", LogMessage.MessageType.INFO);
						}
						else
						{
							log("write start ... ", LogMessage.MessageType.INFO);

							txMsgAddress = new CANMessageSdoStd(sdo_client_id, sdo_fn_write, sdo_upg_index, 
																			sdo_sub_wraddr, upgradeRec.dataAddress);

							send(txMsgAddress);
						}
					}

					delayPollStatus = 0;
					statoUpgrade++;
					break;

				case	6:		// attesa write init
					if( rxMsg != null )
					{
						writeStat = can_data[3] & 0xFF;		// piglia il sub per vedere la risposta al sub 4

						String strRecordNum = String.format("write record .. %d/%d (len:%d)", cntAddrPack, alSREC.size(), upgradeRec.dataSize);

						if( (rxMsg.getId() == sdo_server_id) && (writeStat == 0x04) )		// setup write ok ? ... procede
						{

							if( cntAddrPack == 0 )
							{
	                			//System.out.println("cpu -> setup write ok... ");
								if( traceInfo.isSelected() )								
									log("cpu -> setup write ok...  ", LogMessage.MessageType.INFO);
							}
							else
							{
	                			//System.out.println("cpu -> write ok... ");
								if( traceInfo.isSelected() )								
									log("cpu -> write ok... ", LogMessage.MessageType.INFO);
							}

							int sub_index = 0x80;		// il caricamento avviene da sub=0x80 a sub=0xFF;

							if( msgJUMBO.isSelected() )		// se deve inviare con i jumbo...
							{

								txMsgData = new CANMessageJumbo(sdo_client_id, sdo_fn_write, sdo_upg_index, upgradeRec.dataBytes);
								send(txMsgData);

								//System.out.println("write record .. " + String.format("%d (%d)", cntAddrPack, upgradeRec.dataSize));					
								if( traceInfo.isSelected() )								
									log(strRecordNum, LogMessage.MessageType.INFO);
								else
									logUpdateLastMessage(strRecordNum, LogMessage.MessageType.INFO);
							}
							else
							{
								int np;
								
								for(np=0; np<upgradeRec.dataSize/4; np++)
								{
									byte [] dataPack = new byte[4];

									for(int nb=0; nb<4; nb++)		// ogni frame spediamo m4 bytes (expedited only)
										dataPack[nb] = upgradeRec.dataBytes[np*4+nb];

									txMsgData = new CANMessageSdoStd(sdo_client_id, sdo_fn_write, sdo_upg_index, sub_index, dataPack);
									sub_index++;
									send(txMsgData);

								}
								//System.out.println("write record .. " + String.format("%d (%d)", cntAddrPack, upgradeRec.dataSize));

								if( traceInfo.isSelected() || traceData.isSelected() )								
									log(strRecordNum, LogMessage.MessageType.INFO);
								else
									logUpdateLastMessage(strRecordNum, LogMessage.MessageType.INFO);
										
								int totSent = np * 4;
								
								if( totSent != upgradeRec.dataSize )
								{
	                				//System.out.println("lost record data ... " + String.format("%d - %d", totSent, upgradeRec.dataSize));
									if( traceInfo.isSelected() )								
										log(strRecordNum, LogMessage.MessageType.INFO);
								}
							}

							cntDataPack++;

							statoUpgrade++;
						}
						else
						{

						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 100 )
						{
							delayPollStatus = 0;
							log("waiting ... ", LogMessage.MessageType.INFO);

							send(txMsgStatus);
						}
					}

					break;
					
				case	7:		// avvia programmazione dati inviati: invia il prossimo indirizzo di flash da scrivere
					cntDataPack = 0;

					cntAddrPack++;		// avanti il prossimo

					if( cntAddrPack >= alSREC.size() )		// se i record sono finiti ...
					{
						//System.out.println("write end .. " + String.format("%d", cntAddrPack));

						log(String.format("write end .. %d", cntAddrPack), LogMessage.MessageType.INFO);


							// invia un address dummy per completare la scrittura dell'ultimo record inviato
						txMsgAddress = new CANMessageSdoStd(sdo_client_id, sdo_fn_write, sdo_upg_index, 
																	sdo_sub_wraddr, 0x80000);
						send(txMsgAddress);

						delayPollStatus = 0;
						statoUpgrade++;						// passa avanti
					}
					else
					{
						upgradeRec = alSREC.get(cntAddrPack);

//						System.out.println("write record/addr .. " + String.format("%d (0x%08X)", cntAddrPack, upgradeRec.dataAddress));					
						//??System.out.println("write addr .. " + String.format("0x%08X", upgradeRec.dataAddress));					

						if( traceInfo.isSelected() )								
							log(String.format("write addr .. 0x%08X", upgradeRec.dataAddress), LogMessage.MessageType.INFO);

							// invia l'address del prossimo blocco dati
						txMsgAddress = new CANMessageSdoStd(sdo_client_id, sdo_fn_write, sdo_upg_index, 
																	sdo_sub_wraddr, upgradeRec.dataAddress);

						send(txMsgAddress);

						delayPollStatus = 0;
						statoUpgrade = 6;					// aspetta che finisca di scrivere
					}
					break;

				case	8:	// attesa write ok ultimo blocco dati
					if( rxMsg == null )
					{
						break;
					}

					writeStat = can_data[3] & 0xFF;		// piglia il sub per vedere la risposta al sub 4

					if( (rxMsg.getId() == sdo_server_id) && (writeStat == 0x04) )		// setup write ok ? ... procede
					{

                		System.out.println("end write ok... ");
						log("end write ok... ", LogMessage.MessageType.INFO);
						statoUpgrade++;
					}
					break;

				case	9:		// richiesta calcolo CRC
                	System.out.println("do crc calc... ");
					log("do crc calc... ", LogMessage.MessageType.INFO);
					send(txMsgDoCrcCalc);
					statoUpgrade++;
					break;

				case	10:		// attesa fine calcolo CRC
					if( rxMsg != null )
					{
						crcStat = can_data[7] & 0xFF;

						if( rxMsg.getId() == sdo_server_id )		// erase terminato ? ... procede
						{
							if( crcStat == 0x01 )
							{
	                			System.out.println("crc OK ... ");
								log("crc OK ... ", LogMessage.MessageType.INFO);
								statoUpgrade++;
							}
							else
							{
								if( crcStat == 0x03 )
								{
		                			System.out.println("crc Fail ... ");
									log("crc Fail ... ", LogMessage.MessageType.INFO);
									statoUpgrade++;
								}
							}
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgStatus);
						}
					}
					break;
					
				case	11:

					if( rxMsg != null )
					{
						if( rxMsg.getId() == sdo_server_id && rxMsg.getSubIndex() == 0x07 )		// crc programmato ?
						{ 
							byte [] sdoData = rxMsg.getSdoData();
	                		System.out.println(String.format("crc Prog ... : %02X%02X%02X%02X", 
															sdoData[0], sdoData[1], sdoData[2], sdoData[3]));
							log(String.format("crc Prog ... : %02X%02X%02X%02X", 
															sdoData[0], sdoData[1], sdoData[2], sdoData[3]), LogMessage.MessageType.INFO);
							statoUpgrade++;
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgRdCrcProg);
						}
					}
					break;


				case	12:

					if( rxMsg != null )
					{
						if( rxMsg.getId() == sdo_server_id && rxMsg.getSubIndex() == 0x08 )		// crc programmato ?
						{ 
							byte [] sdoData = rxMsg.getSdoData();

	                		System.out.println(String.format("crc Calc ... : %02X%02X%02X%02X", 
															sdoData[0], sdoData[1], sdoData[2], sdoData[3]));
							log(String.format("crc Calc ... : %02X%02X%02X%02X", 
															sdoData[0], sdoData[1], sdoData[2], sdoData[3]), LogMessage.MessageType.INFO);
							statoUpgrade++;
						}
					}
					else
					{
						delayPollStatus++;

						if( delayPollStatus > 50 )
						{
							delayPollStatus = 0;

							send(txMsgRdCrcCalc);
						}
					}
					break;

				case	13:
//                	System.out.println("crc verify... ");

//					System.out.println("disable prog ... ");
					log("disable prog ... ", LogMessage.MessageType.INFO);

					send(txMsgDisProg);
					statoUpgrade++;
					break;

				case	14:
//                	System.out.println("upgrade end... ");

					upgradeEndTime  = System.currentTimeMillis();

					long upgradeDeltaTime = upgradeEndTime- upgradeStartTime;

					long upgradeMinTime = upgradeDeltaTime / 60000; 
					long upgradeSecTime = (upgradeDeltaTime / 1000) % 60; 
					long upgradeMsecTime = upgradeDeltaTime % 1000; 

					String strUpgEnd = String.format("End Upgrade: elapsed %02d:%02d.%dmsec - nFrame: %d", upgradeMinTime, upgradeSecTime, upgradeMsecTime, cntTotSent);

					log(strUpgEnd, LogMessage.MessageType.INFO);

		            System.out.println(strUpgEnd);

					upgradeRunning = false;
					timerUpgrade.cancel();

					upgradeButton.setText("Upload");
					break;
			}
					
        }
    }

	/** Process the response of readState SDO request
	 * 
	 * @param data SDO response data
	 */
	protected void processReadStateSDOResponse(byte[] data)
    {
    	// I byte sono: [4]=stato, [5]=cnt used, [6]=cnt present, [7]=vuoto
        if (data.length < 3) {
            log("SDO response too short", LogMessage.MessageType.ERROR);
            return;
        }

        int stato   = data[4] & 0xFF;
        int used    = data[5] & 0xFF;
        int present = data[6] & 0xFF;

        String info = String.format("Read State → Stato: %d, Sensori usati: %d, Sensori presenti: %d",
                                    stato, used, present);
        log(info, LogMessage.MessageType.INFO);
    }
	
	/** Process the response of readSensor SDO request
	 * * @param data SDO response data
	 */
	protected void processReadSensorSDOResponse(byte[] data) {
		
	    if (data.length < 5) {
	        log("Risposta SDO vuota.", LogMessage.MessageType.ERROR);
	        return;
	    }

	    int subIndex = data[3] & 0xFF;
	    String info = "";

	    switch (subIndex) {
	        case 0x00: // Sub disponibili
	            int disponibili = data[4] & 0xFF;
	            info = String.format("Sub-index 00 → Numero sub disponibili: %d", disponibili);
	            break;

	        case 0x02: // Serial Number (4 byte)
	            if (data.length >= 8) {
	                // Ricostruzione Little Endian: il byte meno significativo è il primo (data[4])
	                long value = ((data[4] & 0xFFL)) |
	                             ((data[5] & 0xFFL) << 8) |
	                             ((data[6] & 0xFFL) << 16) |
	                             ((data[7] & 0xFFL) << 24);
	                
	                String label = (subIndex == 0x01) ? "Part Number" : "Serial Number";
	                info = String.format("Sub-index %02X → %s: %d (0x%08X)", subIndex, label, value, value);
	            } else {
	                info = String.format("Sub-index %02X → Dati insufficienti per 4 byte", subIndex);
	            }
	            break;

	        case 0x02: // Serial Number
	            int serialNumber = data[4] & 0xFF;
	            info = String.format("Sub-index 02 → Serial Number: %d", serialNumber);
	            break;

	        case 0x03: // Sensor Name
	            StringBuilder sb = new StringBuilder();
	            
	            // I 4 caratteri sono nei byte 4, 5, 6, 7 del payload
	            for (int i = 4; i < data.length && i <= 7; i++) {
	                char c = (char) (data[i] & 0xFF);
	                if (c >= 32 && c <= 126) {
	                    sb.append(c);
	                }
	            }
	            info = String.format("Sub-index 03 → Nome Sensore: \"%s\"", sb.toString().trim());
	            break;

	        case 0x04: // Extra info (NodeID, Used, Present)
	            if (data.length >= 7) {
	                int nodeID  = data[4] & 0xFF;
	                int used    = data[5] & 0xFF;
	                int present = data[6] & 0xFF;
	                
	                info = String.format("Sub-index 04 → NodeID: %d, Usati: %d, Presenti: %d", 
	                                     nodeID, used, present);
	            } else {
	                info = "Sub-index 04 → Dati insufficienti (richiesti 3 byte)";
	            }
	            break;

	        default:
	            info = String.format("Sub-index 0x%02X → Dato: %d (non specifico)", 
	                                 subIndex, data[4] & 0xFF);
	            break;
	    }

	    log(info, LogMessage.MessageType.INFO);
	}
	

    /**
     * Receive can message (called via listener)
     * 
     * @param canmsg CAN message
     */
    @Override
    public void receiveCANMessage(CANMessage canmsg) 
    {
    	long system_timestamp = System.currentTimeMillis();
		long frame_absTimestamp = system_timestamp - absTimestamp;
		long frame_relTimestamp = system_timestamp - relTimestamp;

		relTimestamp = system_timestamp;
		
		
		byte[] data = canmsg.getData();

	    if(countWaitingSDOResponse > 0 && canmsg.getId() == 0x581 && data.length >= 4 && data[0] == 0x42 && data[2] == 0x22) {
	        
            // readState
            if(data[1] == 0x00 && data[3] == 0x00) {
            	if( traceData.isSelected() )
            		log(new LogMessage(canmsg, null, LogMessage.MessageType.IN, frame_absTimestamp, frame_relTimestamp));
                processReadStateSDOResponse(data);
                countWaitingSDOResponse--;
            }
            // readSensor
            else if(data[1] != 0x00) {
            	if( traceData.isSelected() )
            		log(new LogMessage(canmsg, null, LogMessage.MessageType.IN, frame_absTimestamp, frame_relTimestamp));
                processReadSensorSDOResponse(data);
                countWaitingSDOResponse--;
            }
        }
		

		if( traceData.isSelected() )
		{
        	log(new LogMessage(canmsg, null, LogMessage.MessageType.IN, frame_absTimestamp, frame_relTimestamp));
		}

		if( upgradeRunning )
		{
			CAN_PostUpgradeMsg(canmsg);
		}
    }
    
