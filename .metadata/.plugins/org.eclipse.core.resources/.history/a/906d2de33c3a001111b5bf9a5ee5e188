    private void openButtonActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_connectionButtonActionPerformed

		//StartUpgradeTask();
		
        if (openButton.getText().equals("CloseCom")) 
		{
            try {
	            usbtin.closeCANChannel();		// mettiamo in modalita' config 
				usbtin.disconnectSerialPort();
                log("Disconnected", LogMessage.MessageType.INFO);

                System.out.println("Disconnected");

				
            } catch (USBtinException e) {
                log(e.getMessage(), LogMessage.MessageType.ERROR);
            }

            openButton.setText("OpenCom");

			connectionLabel.setText("[DISCONNECTED]");
			connectionLabel.setForeground(Color.black);
			//connectionLabel.setBackground(Color.lightGray);

            bitRate.setEnabled(true);
            serialPort.setEnabled(true);

            sendButton.setEnabled(false);
            readStateButton.setEnabled(false);
            writeStateButton.setEnabled(false);
            workdayButton.setEnabled(false);
			
            jmpAppButton.setEnabled(false);
            jmpLoaButton.setEnabled(false);
            upgradeButton.setEnabled(false);
            
            readSensorButton.setEnabled(false);
            sensorNum.setEnabled(false);


            openmodeComboBox.setEnabled(true);
        } 
		else 
		{
            try {


				if( usbtin.connectSerialPort((String) serialPort.getSelectedItem()) )
				{
						// fino a qui siamo riusciti ad aprire la porta seriale				
	                usbtin.closeCANChannel();		// mettiamo in modalita' config 

	    			/** USBtin firmware version */
	    			String firmwareVersion = usbtin.getFirmwareVersion();

					if( firmwareVersion == null )		// se non risponde ... forse non ci sta
					{
						log("Timeout! USBtin doesn't answer. Right port?", LogMessage.MessageType.INFO);    			/** USBtin hardware version */

						usbtin.disconnectSerialPort();
		                log("Disconnected", LogMessage.MessageType.INFO);

		                System.out.println("Disconnected");
					}
					else
					{
		                openButton.setText("CloseCom");
		                connectionLabel.setText("[CONNECTED]");
						//connectionLabel.setBackground(Color.green);

						Color  verdeScuro  = new Color(0, 150,  0);
						connectionLabel.setForeground(verdeScuro);

		                bitRate.setEnabled(false);
		                serialPort.setEnabled(false);

		                sendButton.setEnabled(true);
		                readStateButton.setEnabled(true);
		                writeStateButton.setEnabled(true);
		                workdayButton.setEnabled(true);

			            jmpAppButton.setEnabled(true);
			            jmpLoaButton.setEnabled(true);
			            
			            readSensorButton.setEnabled(true);
			            sensorNum.setEnabled(true);


		            	upgradeButton.setEnabled(true);
		                openmodeComboBox.setEnabled(false);


		    			String hardwareVersion = usbtin.getHardwareVersion();
		    			String serialNumber = usbtin.getSerialNumber();

						String strConnMsg = "Connected to USBtin (FW" + firmwareVersion + "/HW" + hardwareVersion + ", SN: " + serialNumber+ ")";
					
						log(strConnMsg, LogMessage.MessageType.INFO);

		                System.out.println(strConnMsg);

						usbtin.setCANBaudrate(Integer.parseInt((String) bitRate.getSelectedItem()));
	                	usbtin.openCANChannel((USBtin.OpenMode) openmodeComboBox.getSelectedItem());

		                if (absTimestamp == 0) 
						{
		                    relTimestamp = absTimestamp = System.currentTimeMillis();
		                }


					}
				}
            } 
			catch (USBtinException e) 
			{
                log(e.getMessage(), LogMessage.MessageType.ERROR);
            }
        }
