	private boolean parseSREC(File sfile)
	{	
		boolean retval = false;

		if(sfile != null && sfile.exists())
		{
			try
			{	
				RecordNum = 0;
				alSREC.clear(); 

				BufferedReader br = new BufferedReader(new FileReader(sfile));

				try
				{
					String line = br.readLine();

					while (line != null) 
					{
						if( line.startsWith("S1") || line.startsWith("S2") || line.startsWith("S3") )
						{   
							SREC newSrec = new SREC(line);
							
							if( !isSRECDataEmpty(newSrec.data) )
							{
								alSREC.add(newSrec);

								RecordNum++;


								if( traceInfo.isSelected() )
								{
									String strSrec = String.format("recno: %4d", RecordNum) + String.format(" - addr: %08X", newSrec.dataAddress)  + String.format(" - size: %4d", newSrec.dataSize);
									System.out.println(strSrec);
									log(strSrec, LogMessage.MessageType.INFO);
								}

////								System.out.println(String.format("recno: %d", RecordNum) + String.format(" - addr: %08X", newSrec.address) + String.format(" - size: %4d", newSrec.counter));
////								System.out.println(String.format("recno: %4d", RecordNum) + " - addr: " + newSrec.address + String.format(" - size: %4d", newSrec.dataSize));


/* debug formattazione */
/*								System.out.println(String.format("recno: %4d", RecordNum) + String.format(" - addr: %08X", newSrec.dataAddress)  + String.format(" - size: %4d", newSrec.dataSize));

								if( RecordNum == 1 || RecordNum == 1583 )
								{
									System.out.print("recdata: <");

									if( newSrec.dataBytes != null )
									{
									    for (int i = 0; i < newSrec.dataBytes.length; i++) 
										{
	                						System.out.print(String.format("%02x ", newSrec.dataBytes[i]));
	            						}
									}
									System.out.println(">.");
								}

*/						}
							
							
						}
						line = br.readLine();
					}
				}
				finally
				{
					if(br != null)
						br.close();	
				}
					
				retval = true;
			}
			catch(SecurityException se)
			{
				System.out.println("parseSREC SecurityException: \n" + se.getMessage());
				retval = false;
			}
			catch(NullPointerException npe)
			{
				System.out.println("parseSREC NullPointerException: \n" + npe.getMessage());
				retval = false;
			}
			catch(FileNotFoundException fnfe)
			{
				System.out.println("parseSREC FileNotFoundException: \n" + fnfe.getMessage());
				retval = false;
			}
			catch(IOException ioe)
			{
				System.out.println("parseSREC IOException: \n" + ioe.getMessage());
				retval = false;
			}
		}
		else
		{
			System.out.println("il file upgrade non esiste !!");
		}
		return retval;	
	}

	private boolean isSRECDataEmpty(String data)
	{
		for(char c : data.toCharArray())
		{
			if(!Character.toString(c).toLowerCase().equals("f"))
			{
				return false;
			}	
		}
		return true;
	}

